import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <img src="#" alt="" />
      <p>
        Crafted where empathy meets innovation. Designed to help creators grow
        with grace — through art that’s human, adaptive, and timeless.
      </p>
    </main>
    <Footer />
  </body>
</html>
