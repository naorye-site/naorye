---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import logo from "../assets/NAORYE.svg";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
        <img src={logo.src} alt="NAORYE logo" />
        <p>
          Crafted where empathy meets innovation. Designed to help creators grow
          — through art that’s human, adaptive, but timeless.
        </p>
    </main>
    <Footer />
  </body>
</html>

<style>
  main{
    gap: .5em;
    display: flex;
    min-height: 70vh;
    align-items: center;
    flex-direction: column;
    justify-content: center;
  }
  img {
    max-width: 80%;
    margin: 0 auto;
  }
  p{
    margin-block: 0;
    text-align: center;
  }
</style>
